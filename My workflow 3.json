    {
      "parameters": {
        "jsCode": "const data = [];\n\nfor (let i = 1; i <= 1000; i++) {\n  const statusOptions = [\"Paid\", \"Unpaid\", \"Overdue\"];\n  const status = statusOptions[Math.floor(Math.random() * statusOptions.length)];\n\n  data.push({\n    json: {\n      \"Customer Id\": `CUST${String(i).padStart(4, '0')}`,\n      \"Customer Name\": `Customer ${i}`,\n      \"Customer Email\": `customer${i}@example.com`,\n      \"Customer Phone\": `0300${Math.floor(1000000 + Math.random() * 9000000)}`,\n      \"Invoice Due\": \"2025-01-01\",\n      \"Payment Status\": status,\n      \"Payment Date\": status === \"Paid\" ? \"2025-01-05\" : \"\",\n      \"Due Date\": \"2025-01-15\"\n    }\n  });\n}\n\nreturn data;\n"
      },
