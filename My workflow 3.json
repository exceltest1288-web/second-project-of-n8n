    {
      "parameters": {
        "jsCode": "const data = $input.first().json.data;\n\nconst totalRecords = data.length;\nconst paidCount = data.filter(r => r[\"Payment Status\"] === \"Paid\").length;\nconst unpaidCount = data.filter(r => r[\"Payment Status\"] === \"Unpaid\").length;\nconst overdueCount = data.filter(r => r[\"Payment Status\"] === \"Overdue\").length;\n\nconst summary = {\n  totalRecords,\n  paidCount,\n  unpaidCount,\n  overdueCount,\n  paidPercentage: ((paidCount / totalRecords) * 100).toFixed(2),\n  unpaidPercentage: ((unpaidCount / totalRecords) * 100).toFixed(2),\n  overduePercentage: ((overdueCount / totalRecords) * 100).toFixed(2)\n};\n\nreturn [{ json: summary }];"
      },
      "id": "01275a5e-9a3a-45c8-9a9f-1d82929ea81c",
      "name": "Summarize Data",
